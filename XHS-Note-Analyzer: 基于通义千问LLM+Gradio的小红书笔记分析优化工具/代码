# 帮博主 / 运营分析小红书笔记质量，优化标题、内容、标签，提升曝光和点赞量（非商用，仅个人学习）
import datetime
import os
import threading

import gradio as gr
from openai import OpenAI


# 创建Gradio界面

class CostAnalysisPipeline:
    def __init__(self, name):
        self.name = name

    # 调用大模型API
    @classmethod
    def get_completion(cls, messages):
        client = OpenAI(api_key=os.getenv("DASHSCOPE_API_KEY"),
                        base_url="https://dashscope.aliyuncs.com/compatible-mode/v1")

        response = client.chat.completions.create(
            model='qwen3-max-2025-09-23',
            messages=messages,
            temperature=0,  # 有数字计算，给较低的temperature
        )
        return response

    # 使用大模型进行问答
    @classmethod
    def LLM_QA(cls, llm_q):
        # 构建提示词模板
        qa_template = f"""
        ### 角色设定 ###
        你是一位拥有5年以上经验的资深小红书内容运营专家、爆款笔记分析师。精通小红书平台规则、流量逻辑、标题文案、标签策略与内容结构优化。

        ### 执行要求 ###
        - **数据真实性**：只从给定的笔记内容中提取信息，严禁编造数据、点赞量、标签热度等。
        - **结构化输出**：优先使用 Markdown 表格呈现提取信息与对比结果，核心结论用**加粗**突出。
        - **逻辑性**：分析严格遵循「现状描述 → 问题诊断 → 优化建议」的结构。
        - **专业性**：使用小红书运营专业术语（如：钩子、完读率、标签权重、流量池、爆款结构等）。
        - **可落地性**：所有优化建议必须具体、可直接修改使用，不提供空泛、无法执行的指导。
        -**平台合规**：分析仅用于学习与内容优化，不涉及违规引流、刷量、搬运等行为。

        ### 待处理问题 ###
        {llm_q}
        """
        try:
            # 打印开始询问大模型的时间
            messages = [{"role": "user", "content": qa_template}]
            # 调用OpenAI API获取回答
            response = cls.get_completion(messages)
            # 提取回答内容
            answer = response.choices[0].message.content.strip() if response.choices else "无法提供答案"
            # print(f"完整回答: {answer}")
            return answer
        except Exception as e:
            # 捕获并打印API调用异常
            print(f"{'*' * 100}\nAPI调用失败: {e}\n{'*' * 100}")
            return "无法提供答案"

    # 1.提取核心信息
    def extract_financial_data(self, report_text):
        print(f'{self.name}: 从小红书笔记提取核心信息..')

        # 构建提取关键指标的提示
        prompt = prompt = f'''
            ### 任务目标 ###
            你是一个精准的小红书笔记信息提取引擎。请从以下原始笔记文本中提取关键信息，并以Markdown表格形式呈现。

            ### 摘要提取 ###
            提取笔记标题作为核心标识，所有信息需与该笔记一一对应。

            ### 笔记信息提取清单 ###
            - 笔记标题 (NOTE_TITLE)：完整提取，无删减
            - 核心内容 (CORE_CONTENT)：150字以内总结笔记核心表述，保留关键信息
            - 标签（Hashtag）(HASHTAG)：提取所有以#开头的标签，用英文逗号分隔
            - 发布时间 (PUBLISH_TIME)：从文本中识别，格式为YYYY-MM-DD，无则标注"未披露"
            - 笔记类型 (NOTE_TYPE)：仅限选择「干货/种草/日常/资讯/故事/其他」中的一种
            - 核心卖点 (CORE_SELLING_POINT)：提取笔记中突出的核心价值点，100字以内

            ### 要求 ###
            - 必须严格按照提取清单中指定的信息项进行提取，不得新增/遗漏字段。

            ### 输出要求 ###
            1. 若包含多篇笔记数据，按文本中出现顺序排列。
            2. 表格必须包含所有提取清单列，或直接以横向表格呈现所有提取字段。
            3. 若某字段数据缺失，统一标注“未披露”。
            4. 核心内容、核心卖点需精简提炼，避免照搬原文大段内容。

            输入数据：{report_text}
        '''

        # 调用LLM_QA方法获取回答
        return self.LLM_QA(prompt)

    # 2.深度分析数据
    def analyze_financial_indicators(self, financial_data):
        print(f'{self.name}: 深度分析数据..')

        # 构建分析财务指标的提示
        prompt = f'''
                    ### 任务目标 ###
                    作为资深小红书内容运营分析师，请对提取的笔记核心信息进行深度解读。

                    ### 分析维度 ###
                    1. **标题吸睛度**：判断标题是否包含钩子（如提问/数字/痛点）、核心关键词，评估吸引用户点击的潜力（低/中/高）。
                    2. **内容结构**：分析内容逻辑是否清晰（总分总/问题-解决方案/无明确结构）、是否包含干货（具体方法/数据/案例），评估完读率潜力（低/中/高）。
                    3. **标签适配性**：判断标签与笔记核心内容的匹配度（完全匹配/部分匹配/不匹配），评估标签对流量的正向作用（低/中/高）。
                    4. **受众适配**：明确笔记适配的核心人群（年龄/职业/兴趣维度），分析内容与目标受众需求的契合度（低/中/高）。

                    ### 格式要求 ###
                    - 使用“结论先行”的表达方式，每个分析维度先给出核心结论，再补充分析依据。
                    - 关键评估结果请用Markdown表格汇总（维度/核心结论/评估依据）。
                    - 分析依据需严格基于提取的笔记信息，禁止编造。

                    输入数据：{financial_data}
                '''
        # 调用 LLM_QA 方法获取回答
        return self.LLM_QA(prompt)

    # 3.预测曝光效果
    def predict_future_trends(self, financial_data):
        print(f'{self.name}: 预测曝光效果..')

        # 构建预测未来趋势的提示
        prompt = f'''
                    ### 任务目标 ###
                    基于小红书笔记的内容分析结果，对该笔记的曝光效果进行审慎预测

                    ### 预测逻辑 ###
                    1. **基础数据复核**：先评估标题吸睛度、内容质量、标签适配性、受众适配度的综合得分（1-10分）。
                    2. **逻辑推导**：基于综合得分和小红书行业爆款规律，给出“乐观”、“中性”、“悲观”三种情景下的曝光效果假设。
                    3. **效果预测**：给出笔记曝光量区间、点赞/收藏率、长尾曝光潜力的具体预测结果表。

                    ### 注意事项 ###
                    - 明确标注预测所基于的核心假设条件（如“乐观情景基于标题吸睛度满分+标签高热度”）。
                    - 必须包含预测数据表格，所有数值为区间/等级类结果，禁止编造具体精准数字。
                    - 长尾曝光潜力仅标注“高/中/低”三个等级，基于内容的实用价值和时效性判断。

                    输入数据：{financial_data}
                '''
        # 调用LLM_QA方法获取回答
        return self.LLM_QA(prompt)

    # 4.优化建议
    def optimize_costs(self, financial_data):
        print(f'{self.name}: 优化建议...')

        # 构建优化成本的提示
        prompt = f'''
                    ### 任务目标 ###
                    对小红书笔记进行全方位优化分析，并提供可直接落地的爆款化改进建议，提升笔记曝光量、点赞率和完读率。

                    ### 分析要点 ###               
                    1.  **优化痛点评估**：结合笔记深度分析结果，精准定位标题、标签、内容、排版中存在的薄弱点（如标题无钩子、标签适配度低、内容冗余等）。
                    2.  **笔记优化策略**：针对识别出的弱点，围绕以下4个核心方向，提出可直接修改使用的具体建议：
                        ① 标题优化：提供3个吸睛备选标题，贴合小红书平台调性，包含钩子、关键词，提升点击量；
                        ② 标签调整：推荐5-8个高流量适配标签（含1-2个行业大标签、3-4个精准细分标签），提升流量匹配度；
                        ③ 内容优化：针对冗余内容进行精简，突出核心干货/亮点，补充用户关注的细节，提升完读率；
                        ④ 排版建议：给出分段、表情使用、重点标注的具体方法，贴合小红书阅读习惯，提升视觉舒适度。
                    

                    ### 输出要求 ###
                    - 建议需具备小红书平台针对性，贴合平台用户偏好（如标题简洁吸睛、排版清晰、标签精准），拒绝空泛建议。
                    - 所有建议可直接落地执行，标题、标签、排版需给出具体示例，内容优化需明确标注修改部位和修改方向。

                    输入数据：{financial_data}
                '''
        # 调用LLM_QA方法获取回答
        return self.LLM_QA(prompt)

    # 生成最终报告
    def generate_final_report(self, extracted_data, analysis_result, prediction_result, optimization_result):
        print(f'{self.name}: 生成最终报告..')

        # 构建生成最终报告的提示
        prompt = f'''
                    ### 任务目标 ###
                    整合所有分析模块，生成一份专业、易落地的小红书笔记优化分析报告。

                    ### 输出要求 ###
                    - 必须包含报告结构中定义的所有部分，内容需逻辑连贯、重点突出。

                    ### 报告结构 ###
                    1. **报告名称**：使用提取的笔记标题生成报告名称，格式为：【小红书笔记分析】+ 笔记标题。
                    2. **核心摘要**：一句话总结笔记当前的质量水平、核心问题及优化后可达到的曝光效果预期。
                    3. **笔记基础信息表**：汇总提取的所有笔记核心信息（标题、核心内容、标签、发布时间、笔记类型、核心卖点）。
                    4. **深度解读**：整合深度分析结果，包含4个维度：标题吸睛度、内容结构、标签适配性、受众适配度。
                    5. **曝光效果预测**：完整呈现不同情景下（乐观/中性/悲观）的曝光量区间、点赞/收藏率、长尾曝光潜力。
                    6. **优化方案**：整合所有优化建议，按标题优化、标签调整、内容优化、排版建议分类呈现。
                    7. **核心结论**：总结笔记的核心优势、主要短板及最优先级的优化动作（1-2条）。

                    ### 排版要求 ###
                    - 使用二级标题（##）对报告各部分进行分类，三级标题（###）拆分维度细节。
                    - 表格需使用Markdown格式呈现，核心结论和关键数据用**加粗**显示。
                    - 所有分析和建议需严格基于输入材料，禁止编造信息。

                    输入材料：
                    - 核心数据：{extracted_data}
                    - 深度分析：{analysis_result}
                    - 曝光预测：{prediction_result}
                    - 优化建议：{optimization_result}
                '''
        # 调用LLM_QA方法获取回答
        return self.LLM_QA(prompt)

    # 分析数据
    def analyze_data(self, report_text, res):
        print(f'{"*" * 80}\n{datetime.datetime.now()}')
        print(f'{self.name}: 开始分析数据..')

        # 1.提取财务指标
        financial_data = self.extract_financial_data(report_text)

        # 2.分析财务指标
        analysis_result = self.analyze_financial_indicators(financial_data)

        # 3.预测未来趋势
        prediction_result = self.predict_future_trends(financial_data)

        # 4.成本优化建议
        optimization_result = self.optimize_costs(financial_data)

        # 生成最终报告
        final_report = self.generate_final_report(
            financial_data, analysis_result, prediction_result, optimization_result
        )

        print("len(final_report): ", len(final_report))
        res.extend([final_report])






# 实际调用运行过程。比较两个报告
def compare(input1):
    # 创建CostAnalysisPipeline实例
    pipeline1 = CostAnalysisPipeline('帮博主 / 运营分析小红书笔记质量，优化标题、内容、标签，提升曝光和点赞量')

    # 使用多线程：让2个报告可以同时分析（节省时间）
    res1 = []  # 用来接收报告1的结果
    t1 = threading.Thread(target=pipeline1.analyze_data, args=(input1, res1))
    t1.start()  # 启动线程
    t1.join()  # 等待让前面2个线程都结束

    # 把多线程分析得到的报告用result1,result2,存储为final_report1,final_report2
    final_report1, = res1
    print(f"report1完成：{datetime.datetime.now()}\n-{'#' * 80}")

    # 将报告1和报告2的结果写入md文件
    with open('result/final_report1.md', 'w', encoding='utf-8') as f:
        f.write(final_report1)

    return final_report1

def main():
    with gr.Blocks() as demo:
        gr.Markdown("## 小红书笔记建议报告")
        with gr.Row():
            with gr.Column():
                # 输入框1，用于输入财务报表文本
                input1 = gr.Textbox(label="输入数据 1 (小红书笔记)", placeholder="请输入笔记内容...")

        # 比较按钮
        compare_button = gr.Button("生成报告")
        # 输出框，用于显示比较结果
        compare_output = gr.Markdown(label="比较结果")
        print('input1',input1)
        # 绑定比较按钮到compare函数
        compare_button.click(compare, inputs=[input1], outputs=compare_output)

    demo.launch(share=True)


if __name__ == "__main__":
    main()
